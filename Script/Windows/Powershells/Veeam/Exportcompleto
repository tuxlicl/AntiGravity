# Ruta del archivo CSV de salida
$exportPath = "C:\VeeamReport\Listado_Jobs_VMs.csv"

# Crear carpeta si no existe
$folder = Split-Path $exportPath
if (!(Test-Path $folder)) {
    New-Item -Path $folder -ItemType Directory | Out-Null
}

# Cargar el módulo de Veeam si no está cargado
if (-not (Get-Module -ListAvailable -Name Veeam.Backup.PowerShell)) {
    Import-Module "C:\Program Files\Veeam\Backup and Replication\Backup\Veeam.Backup.PowerShell.dll"
}

# Inicializar lista de resultados
$results = @()

# Obtener todos los jobs
Get-VBRJob | ForEach-Object {
    $job = $_
    $jobObjects = Get-VBRJobObject -Job $job

    foreach ($obj in $jobObjects) {
        $results += [PSCustomObject]@{
            JobName = $job.Name
            VMName  = $obj.Name
            ObjectType = $obj.ObjectType
        }
    }
}

# Exportar a CSV
$results | Export-Csv -Path $exportPath -NoTypeInformation -Encoding UTF8

Write-Host "✅ Exportación completada: $exportPath"
